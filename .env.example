# 将这些变量配置到操作系统或部署平台中，不要在此文件填写真实密钥。
AINAME_MYSQL_DB_URI=mysql+aiomysql://用户名:新密码@127.0.0.1:3306/ainame?charset=utf8mb4
AINAME_POSTGRES_CHECKPOINT_DB_URI=postgresql://用户名:新密码@127.0.0.1:5432/ainame
AINAME_REDIS_URL=redis://127.0.0.1:6379/0

AINAME_DEEPSEEK_API_KEY=替换为重新生成的DeepSeek密钥
AINAME_DEEPSEEK_MODEL=deepseek-chat

AINAME_MAIL_USERNAME=替换为邮箱账号
AINAME_MAIL_PASSWORD=替换为重新生成的邮箱授权码
AINAME_MAIL_FROM=替换为发件邮箱
AINAME_MAIL_PORT=587
AINAME_MAIL_SERVER=smtp.qq.com
AINAME_MAIL_FROM_NAME=ainameapp
AINAME_MAIL_STARTTLS=true
AINAME_MAIL_SSL_TLS=false

AINAME_JWT_SECRET_KEY=替换为至少64字符的新随机密钥
AINAME_JWT_ACCESS_DAYS=1
AINAME_JWT_REFRESH_DAYS=30
